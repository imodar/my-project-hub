/*
  # Security Headers — تُطبَّق على جميع الصفحات

  # منع تضمين التطبيق في iframe من مواقع أخرى
  X-Frame-Options: DENY

  # منع MIME type sniffing
  X-Content-Type-Options: nosniff

  # Referrer Policy
  Referrer-Policy: strict-origin-when-cross-origin

  # X-XSS-Protection مهمل — تعطيله لمنع ثغرات IE القديم
  X-XSS-Protection: 0

  # سياسة الأمان للمحتوى (CSP)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://ptmhrfovbyvpewfdpejf.supabase.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://ptmhrfovbyvpewfdpejf.supabase.co https://ptmhrfovbyvpewfdpejf.supabase.in; connect-src 'self' https://ptmhrfovbyvpewfdpejf.supabase.co wss://ptmhrfovbyvpewfdpejf.supabase.co https://api.aladhan.com https://api.open-meteo.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

  # Permissions Policy — تقييد الوصول للـ APIs الحساسة
  Permissions-Policy: geolocation=(self), camera=(), microphone=(), payment=(), usb=()

  # HTTPS فقط (HSTS)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=86400
