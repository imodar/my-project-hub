# ═══════════════════════════════════════════════════════════════
# متغيرات البيئة المطلوبة — منظم العائلة
# ═══════════════════════════════════════════════════════════════
# انسخ هذا الملف إلى .env وأضف القيم الصحيحة
# NEVER commit the .env file to git (تأكد من وجوده في .gitignore)
# ═══════════════════════════════════════════════════════════════

# ── Supabase (مطلوب) ──────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# ── Sentry Error Tracking (مطلوب في الإنتاج) ─────────────────
# بدون هذا المتغير، لن تُرصد الأخطاء في الإنتاج.
# أنشئ مشروعاً في: https://sentry.io
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ── إصدار التطبيق (مطلوب للـ API versioning) ─────────────────
VITE_APP_VERSION=1.0.0

# ── RevenueCat (للاشتراكات على الموبايل) ─────────────────────
# VITE_REVENUECAT_API_KEY=your-revenuecat-api-key

# ── Analytics (اختياري) ───────────────────────────────────────
# VITE_POSTHOG_KEY=your-posthog-key
# VITE_POSTHOG_HOST=https://app.posthog.com
